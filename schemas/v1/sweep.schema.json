{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/DyrtyJax/embeadings/main/schemas/v1/sweep.schema.json",
  "title": "emBEADings sweep report, schema version 1",
  "type": "object",
  "required": ["schema_version", "report_type", "run_id", "policy", "snapshot", "model", "cache", "parameters", "candidates", "batches", "warnings"],
  "properties": {
    "schema_version": { "const": 1 },
    "report_type": { "const": "sweep" },
    "run_id": { "type": "string", "minLength": 1 },
    "policy": { "$ref": "#/$defs/policy" },
    "snapshot": { "$ref": "#/$defs/snapshot" },
    "model": { "$ref": "#/$defs/model" },
    "cache": { "$ref": "#/$defs/cache" },
    "parameters": {
      "type": "object",
      "required": ["filters", "thresholds", "target_batch_size"],
      "properties": {
        "filters": { "type": "object" },
        "thresholds": { "type": "object" },
        "candidate_policy": { "$ref": "#/$defs/candidate-policy" },
        "target_batch_size": { "type": ["integer", "null"], "minimum": 1 },
        "max_batch_size": { "type": ["integer", "null"], "minimum": 1 }
      },
      "additionalProperties": true
    },
    "candidates": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
    "batches": { "type": "array", "items": { "$ref": "#/$defs/batch-summary" } },
    "batch_diagnostics": { "$ref": "#/$defs/batch-diagnostics" },
    "no_signal": { "$ref": "#/$defs/population-summary" },
    "excluded": { "$ref": "#/$defs/excluded-summary" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "duration_ms": { "type": "number", "minimum": 0 },
    "output_directory": { "type": "string" }
  },
  "additionalProperties": true,
  "$defs": {
    "policy": {
      "type": "object",
      "required": ["read_only", "tracker_mutation_allowed", "advisory", "notice"],
      "properties": {
        "read_only": { "const": true },
        "tracker_mutation_allowed": { "const": false },
        "advisory": { "const": true },
        "notice": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "snapshot": {
      "type": "object",
      "required": ["workspace_id", "beads_version"],
      "properties": {
        "workspace_id": { "type": "string", "minLength": 1 },
        "beads_version": { "type": "string", "minLength": 1 },
        "workspace_path": { "type": ["string", "null"] },
        "source_revision": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": ["model_id", "model_revision"],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "model_revision": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "cache": {
      "type": "object",
      "properties": {
        "hits": { "type": "integer", "minimum": 0 },
        "misses": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "issue_id", "related_issue_id", "similarity", "what_to_verify"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "lane": { "enum": ["dependency", "echo", "overlap"] },
        "issue_id": { "type": "string", "minLength": 1 },
        "related_issue_id": { "type": "string", "minLength": 1 },
        "similarity": { "type": "number", "minimum": -1, "maximum": 1 },
        "structural_context": { "type": "string" },
        "verification_anchor": {
          "type": "object",
          "required": ["category", "operation", "entity_class", "source_field"],
          "properties": {
            "category": { "type": "string", "minLength": 1 },
            "operation": { "type": "string", "minLength": 1 },
            "entity_class": { "type": "string", "minLength": 1 },
            "source_field": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "dependency_evidence": {
          "type": ["object", "null"],
          "properties": {
            "source_id": { "type": "string", "minLength": 1 },
            "target_id": { "type": "string", "minLength": 1 },
            "type": { "type": "string", "minLength": 1 }
          },
          "required": ["source_id", "target_id", "type"],
          "additionalProperties": false
        },
        "what_to_verify": { "type": "string", "minLength": 1 },
        "counterevidence": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        }
      },
      "additionalProperties": true
    },
    "candidate-policy": {
      "type": "object",
      "properties": {
        "max_per_issue": { "type": "integer", "minimum": 1 },
        "max_total": { "type": "integer", "minimum": 1 },
        "baseline_protected": { "type": "integer", "minimum": 0 },
        "dropped_by_lane_cap": { "type": "integer", "minimum": 0 },
        "lane_caps": {
          "type": "object",
          "properties": {
            "dependency": { "type": "integer", "minimum": 0 },
            "echo": { "type": "integer", "minimum": 0 },
            "overlap": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "lanes": {
          "type": "object",
          "properties": {
            "dependency": { "$ref": "#/$defs/lane-metrics" },
            "echo": { "$ref": "#/$defs/lane-metrics" },
            "overlap": { "$ref": "#/$defs/lane-metrics" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "lane-metrics": {
      "type": "object",
      "required": ["qualified", "admitted", "baseline_protected", "dropped_by_lane_cap", "dropped_by_issue_cap", "dropped_by_run_cap"],
      "properties": {
        "qualified": { "type": "integer", "minimum": 0 },
        "admitted": { "type": "integer", "minimum": 0 },
        "baseline_protected": { "type": "integer", "minimum": 0 },
        "dropped_by_lane_cap": { "type": "integer", "minimum": 0 },
        "dropped_by_issue_cap": { "type": "integer", "minimum": 0 },
        "dropped_by_run_cap": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "batch-summary": {
      "type": "object",
      "required": ["batch"],
      "properties": {
        "batch": { "type": "integer", "minimum": 1 },
        "kind": { "enum": ["connected-component", "singleton-envelope"] },
        "review_units": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["issue_ids"],
            "properties": {
              "issue_ids": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            },
            "additionalProperties": true
          }
        },
        "issue_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "issues": { "type": "array" },
        "candidate_count": { "type": "integer", "minimum": 0 }
      },
      "anyOf": [{ "required": ["issue_ids"] }, { "required": ["issues"] }],
      "additionalProperties": true
    },
    "batch-diagnostics": {
      "type": "object",
      "properties": {
        "component_count": { "type": "integer", "minimum": 0 },
        "singleton_component_count": { "type": "integer", "minimum": 0 },
        "agent_envelope_count": { "type": "integer", "minimum": 0 },
        "fragmented_component_count": { "type": "integer", "minimum": 0 },
        "cross_batch_candidate_edges": { "type": "integer", "minimum": 0 },
        "max_batch_size": { "type": "integer", "minimum": 0 },
        "configured_max_batch_size": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "population-summary": {
      "type": "object",
      "required": ["count", "issue_ids"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "issue_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "excluded-summary": {
      "type": "object",
      "required": ["count", "by_reason", "issue_ids"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "by_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "issue_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  }
}

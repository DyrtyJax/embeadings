{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/DyrtyJax/embeadings/main/schemas/v1/sweep.schema.json",
  "title": "emBEADings sweep report, schema version 1",
  "type": "object",
  "required": ["schema_version", "report_type", "run_id", "policy", "snapshot", "model", "cache", "parameters", "candidates", "batches", "warnings"],
  "properties": {
    "schema_version": { "const": 1 },
    "report_type": { "const": "sweep" },
    "run_id": { "type": "string", "minLength": 1 },
    "policy": { "$ref": "#/$defs/policy" },
    "snapshot": { "$ref": "#/$defs/snapshot" },
    "model": { "$ref": "#/$defs/model" },
    "cache": { "$ref": "#/$defs/cache" },
    "parameters": {
      "type": "object",
      "required": ["filters", "thresholds", "target_batch_size"],
      "properties": {
        "filters": {
          "type": "object",
          "properties": {
            "incremental_scope": { "$ref": "#/$defs/incremental-scope" }
          },
          "additionalProperties": true
        },
        "thresholds": { "type": "object" },
        "candidate_policy": { "$ref": "#/$defs/candidate-policy" },
        "target_batch_size": { "type": ["integer", "null"], "minimum": 1 },
        "max_batch_size": { "type": ["integer", "null"], "minimum": 1 }
      },
      "additionalProperties": true
    },
    "candidates": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
    "capped_typed_dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/capped-typed-dependency" }
    },
    "anchor_metrics": { "$ref": "#/$defs/anchor-metrics" },
    "batches": { "type": "array", "items": { "$ref": "#/$defs/batch-summary" } },
    "batch_diagnostics": { "$ref": "#/$defs/batch-diagnostics" },
    "no_signal": { "$ref": "#/$defs/population-summary" },
    "excluded": { "$ref": "#/$defs/excluded-summary" },
    "code_surface_analysis": { "$ref": "#/$defs/code-surface-analysis" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "duration_ms": { "type": "number", "minimum": 0 },
    "output_directory": { "type": "string" }
  },
  "additionalProperties": true,
  "$defs": {
    "policy": {
      "type": "object",
      "required": ["read_only", "tracker_mutation_allowed", "advisory", "notice"],
      "properties": {
        "read_only": { "const": true },
        "tracker_mutation_allowed": { "const": false },
        "advisory": { "const": true },
        "notice": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "code-surface-analysis": {
      "type": "object",
      "required": ["repository_available", "issue_count", "pointer_count", "issues_with_explicit_surfaces", "issues_with_observed_surfaces", "issues_without_surfaces", "worktrees_discovered", "worktrees_associated", "source_counts", "surfaces", "collisions", "warnings"],
      "properties": {
        "repository_available": { "type": "boolean" },
        "repository_revision": { "type": ["string", "null"] },
        "base_reference": { "type": ["string", "null"] },
        "base_revision": { "type": ["string", "null"] },
        "issue_count": { "type": "integer", "minimum": 0 },
        "pointer_count": { "type": "integer", "minimum": 0 },
        "issues_with_explicit_surfaces": { "type": "integer", "minimum": 0 },
        "issues_with_observed_surfaces": { "type": "integer", "minimum": 0 },
        "issues_without_surfaces": { "type": "integer", "minimum": 0 },
        "worktrees_discovered": { "type": "integer", "minimum": 0 },
        "worktrees_associated": { "type": "integer", "minimum": 0 },
        "source_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "surfaces": { "type": "array" },
        "collisions": { "type": "array" },
        "warnings": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "snapshot": {
      "type": "object",
      "required": ["workspace_id", "beads_version"],
      "properties": {
        "workspace_id": { "type": "string", "minLength": 1 },
        "beads_version": { "type": "string", "minLength": 1 },
        "workspace_path": { "type": ["string", "null"] },
        "source_revision": { "type": ["string", "null"] },
        "source_divergence_reasons": {
          "type": "array",
          "items": {
            "enum": [
              "dependency_structure",
              "issue_identity",
              "issue_type",
              "priority",
              "record_count",
              "status",
              "update_marker"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": ["model_id", "model_revision"],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "model_revision": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "cache": {
      "type": "object",
      "properties": {
        "hits": { "type": "integer", "minimum": 0 },
        "misses": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "anchor-metrics": {
      "type": "object",
      "required": ["total", "confidence", "generic_fallback_count", "generic_fallback_rate"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "confidence": {
          "type": "object",
          "required": ["high", "medium", "low"],
          "properties": {
            "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "specificity": {
          "type": "object",
          "required": ["concrete-check", "category-check", "generic"],
          "properties": {
            "concrete-check": { "type": "integer", "minimum": 0 },
            "category-check": { "type": "integer", "minimum": 0 },
            "generic": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "actionable_proxy_count": { "type": "integer", "minimum": 0 },
        "actionable_proxy_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "generic_fallback_count": { "type": "integer", "minimum": 0 },
        "generic_fallback_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "issue_id", "related_issue_id", "similarity", "what_to_verify"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "lane": { "enum": ["dependency", "echo", "overlap"] },
        "issue_id": { "type": "string", "minLength": 1 },
        "related_issue_id": { "type": "string", "minLength": 1 },
        "similarity": { "type": "number", "minimum": -1, "maximum": 1 },
        "structural_context": { "type": "string" },
        "reciprocal_evidence": {
          "type": ["string", "null"],
          "enum": [null, "discriminative-title-token", "discriminative-title-alignment", "sparse-title-alignment", "discriminative-field-phrase"]
        },
        "verification_anchor": {
          "type": "object",
          "required": ["category", "operation", "entity_class", "source_field"],
          "properties": {
            "category": { "type": "string", "minLength": 1 },
            "operation": { "type": "string", "minLength": 1 },
            "entity_class": { "type": "string", "minLength": 1 },
            "source_field": { "type": "string", "minLength": 1 },
            "action": { "type": "string", "minLength": 1 },
            "entity": { "type": "string", "minLength": 1 },
            "outcome_or_invariant": { "type": "string", "minLength": 1 },
            "confidence": { "enum": ["high", "medium", "low"] },
            "extraction_confidence": { "enum": ["high", "medium", "low"] },
            "confidence_scope": { "const": "anchor-extraction" },
            "specificity": { "enum": ["concrete-check", "category-check", "generic"] },
            "check_category": { "enum": ["ownership-boundary", "test", "invariant", "contract", "artifact", "entity-category", "unspecified"] },
            "check_source_field": { "enum": ["title", "description", "acceptance criteria", "design", "notes", "whole-record semantics"] },
            "generic_fallback": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "dependency_evidence": {
          "type": ["object", "null"],
          "properties": {
            "source_id": { "type": "string", "minLength": 1 },
            "target_id": { "type": "string", "minLength": 1 },
            "type": { "type": "string", "minLength": 1 }
          },
          "required": ["source_id", "target_id", "type"],
          "additionalProperties": false
        },
        "candidate_evidence": {
          "type": "object",
          "required": ["evidence_basis", "structural_corroboration", "admission_path", "uncertainty"],
          "properties": {
            "evidence_basis": { "enum": ["semantic-only", "structurally-corroborated"] },
            "structural_corroboration": { "enum": ["none", "shared-parent", "typed-dependency"] },
            "admission_path": { "enum": ["semantic-threshold", "shared-parent-threshold-exception", "dependency-threshold-exception", "reciprocal-neighbor-threshold-exception"] },
            "uncertainty": { "enum": ["no-structural-corroboration", "structural-corroboration-recorded"] }
          },
          "additionalProperties": false
        },
        "what_to_verify": { "type": "string", "minLength": 1 },
        "counterevidence": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        }
      },
      "additionalProperties": true
    },
    "candidate-policy": {
      "type": "object",
      "properties": {
        "max_per_issue": { "type": "integer", "minimum": 1 },
        "max_dependencies_per_issue": { "type": "integer", "minimum": 0 },
        "max_total": { "type": "integer", "minimum": 1 },
        "review_budget": { "$ref": "#/$defs/review-budget" },
        "baseline_protected": { "type": "integer", "minimum": 0 },
        "reciprocal_diagnostics": { "$ref": "#/$defs/reciprocal-diagnostics" },
        "cap_replacements": {
          "type": "array",
          "items": { "$ref": "#/$defs/cap-replacement" }
        },
        "dependency_funnel": { "$ref": "#/$defs/dependency-funnel" },
        "dropped_by_lane_cap": { "type": "integer", "minimum": 0 },
        "lane_caps": {
          "type": "object",
          "properties": {
            "dependency": { "type": "integer", "minimum": 0 },
            "echo": { "type": "integer", "minimum": 0 },
            "overlap": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "lanes": {
          "type": "object",
          "properties": {
            "dependency": { "$ref": "#/$defs/lane-metrics" },
            "echo": { "$ref": "#/$defs/lane-metrics" },
            "overlap": { "$ref": "#/$defs/lane-metrics" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "reciprocal-diagnostics": {
      "type": "object",
      "required": ["admitted", "omitted", "admission_reasons", "omission_reasons"],
      "properties": {
        "admitted": { "type": "integer", "minimum": 0 },
        "omitted": { "type": "integer", "minimum": 0 },
        "admission_reasons": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "omission_reasons": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "additionalProperties": false
    },
    "dependency-funnel": {
      "type": "object",
      "required": ["total_non_parent_typed", "inactive_or_closed_only", "below_qualification", "eligible", "admitted", "omitted_by_per_issue_cap", "omitted_by_lane_cap", "omitted_by_run_cap"],
      "properties": {
        "total_non_parent_typed": { "type": "integer", "minimum": 0 },
        "inactive_or_closed_only": { "type": "integer", "minimum": 0 },
        "below_qualification": { "type": "integer", "minimum": 0 },
        "eligible": { "type": "integer", "minimum": 0 },
        "admitted": { "type": "integer", "minimum": 0 },
        "omitted_by_per_issue_cap": { "type": "integer", "minimum": 0 },
        "omitted_by_lane_cap": { "type": "integer", "minimum": 0 },
        "omitted_by_run_cap": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "cap-replacement": {
      "type": "object",
      "required": ["candidate_id", "governing_cap", "displaced_candidate_ids", "causal_chain"],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "governing_cap": { "type": "string", "minLength": 1 },
        "displaced_candidate_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "causal_chain": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["candidate_id", "event", "resource"],
            "properties": {
              "candidate_id": { "type": "string", "minLength": 1 },
              "event": { "enum": ["qualification-removed", "selection-displaced", "selection-transition", "selection-admitted"] },
              "resource": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "review-budget": {
      "type": "object",
      "required": ["mode", "candidate_limit", "admitted_candidates", "omitted_candidates", "priority_order", "omitted_by_lane"],
      "properties": {
        "mode": { "enum": ["standard", "weekly"] },
        "candidate_limit": { "type": "integer", "minimum": 1 },
        "admitted_candidates": { "type": "integer", "minimum": 0 },
        "omitted_candidates": { "type": "integer", "minimum": 0 },
        "priority_order": {
          "const": ["typed-dependency", "high-confidence-completed-work-echo", "possible-overlap"]
        },
        "omitted_by_lane": {
          "type": "object",
          "required": ["dependency", "echo", "overlap"],
          "properties": {
            "dependency": { "type": "integer", "minimum": 0 },
            "echo": { "type": "integer", "minimum": 0 },
            "overlap": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "lane-metrics": {
      "type": "object",
      "required": ["qualified", "admitted", "baseline_protected", "dropped_by_lane_cap", "dropped_by_issue_cap", "dropped_by_run_cap"],
      "properties": {
        "qualified": { "type": "integer", "minimum": 0 },
        "admitted": { "type": "integer", "minimum": 0 },
        "baseline_protected": { "type": "integer", "minimum": 0 },
        "dropped_by_lane_cap": { "type": "integer", "minimum": 0 },
        "dropped_by_issue_cap": { "type": "integer", "minimum": 0 },
        "dropped_by_dependency_issue_cap": { "type": "integer", "minimum": 0 },
        "dropped_by_run_cap": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "capped-typed-dependency": {
      "type": "object",
      "required": ["source_id", "target_id", "type", "drop_reason"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "target_id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "drop_reason": {
          "enum": ["dependency-per-issue-cap", "lane-cap", "run-cap"]
        }
      },
      "additionalProperties": false
    },
    "batch-summary": {
      "type": "object",
      "required": ["batch"],
      "properties": {
        "batch": { "type": "integer", "minimum": 1 },
        "kind": { "enum": ["connected-component", "singleton-envelope"] },
        "review_units": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["issue_ids"],
            "properties": {
              "issue_ids": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            },
            "additionalProperties": true
          }
        },
        "issue_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "issues": { "type": "array" },
        "candidate_count": { "type": "integer", "minimum": 0 }
      },
      "anyOf": [{ "required": ["issue_ids"] }, { "required": ["issues"] }],
      "additionalProperties": true
    },
    "batch-diagnostics": {
      "type": "object",
      "properties": {
        "component_count": { "type": "integer", "minimum": 0 },
        "singleton_component_count": { "type": "integer", "minimum": 0 },
        "agent_envelope_count": { "type": "integer", "minimum": 0 },
        "fragmented_component_count": { "type": "integer", "minimum": 0 },
        "cross_batch_candidate_edges": { "type": "integer", "minimum": 0 },
        "max_batch_size": { "type": "integer", "minimum": 0 },
        "configured_max_batch_size": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "population-summary": {
      "type": "object",
      "required": ["count", "issue_ids"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "issue_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "incremental-scope": {
      "type": "object",
      "required": ["mode", "changed_active_count", "unchanged_active_count", "unknown_timestamp_count", "deleted_since_checkpoint_count"],
      "properties": {
        "mode": { "enum": ["full", "changed-since", "checkpoint"] },
        "changed_active_count": { "type": "integer", "minimum": 0 },
        "unchanged_active_count": { "type": "integer", "minimum": 0 },
        "unknown_timestamp_count": { "type": "integer", "minimum": 0 },
        "deleted_since_checkpoint_count": { "type": "integer", "minimum": 0 },
        "checkpoint_created_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },
    "excluded-summary": {
      "type": "object",
      "required": ["count", "by_reason", "issue_ids"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "by_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "issue_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/DyrtyJax/embeadings/main/schemas/v1/batch.schema.json",
  "title": "emBEADings review batch manifest, schema version 1",
  "type": "object",
  "required": ["schema_version", "report_type", "run_id", "batch", "policy", "snapshot", "model", "cache", "issues", "neighbor_evidence", "review_rubric"],
  "properties": {
    "schema_version": { "const": 1 },
    "report_type": { "const": "batch" },
    "run_id": { "type": "string", "minLength": 1 },
    "batch": { "type": "integer", "minimum": 1 },
    "kind": { "enum": ["connected-component", "singleton-envelope"] },
    "review_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_ids"],
        "properties": {
          "issue_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        },
        "additionalProperties": true
      }
    },
    "policy": { "$ref": "#/$defs/policy" },
    "snapshot": { "$ref": "#/$defs/snapshot" },
    "model": { "$ref": "#/$defs/model" },
    "cache": { "$ref": "#/$defs/cache" },
    "issues": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "neighbor_evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
    "anchor_metrics": { "$ref": "#/$defs/anchor-metrics" },
    "review_rubric": { "type": "array", "items": { "type": ["string", "object"] } }
  },
  "additionalProperties": true,
  "$defs": {
    "policy": {
      "type": "object",
      "required": ["read_only", "implementation_allowed", "tracker_mutation_allowed", "advisory", "notice"],
      "properties": {
        "read_only": { "const": true },
        "implementation_allowed": { "const": false },
        "tracker_mutation_allowed": { "const": false },
        "advisory": { "const": true },
        "notice": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "snapshot": {
      "type": "object",
      "required": ["workspace_id", "beads_version"],
      "properties": {
        "workspace_id": { "type": "string", "minLength": 1 },
        "beads_version": { "type": "string", "minLength": 1 },
        "workspace_path": { "type": ["string", "null"] },
        "source_revision": { "type": ["string", "null"] },
        "source_divergence_reasons": {
          "type": "array",
          "items": {
            "enum": [
              "dependency_structure",
              "issue_identity",
              "issue_type",
              "priority",
              "record_count",
              "status",
              "update_marker"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": ["model_id", "model_revision"],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "model_revision": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "cache": {
      "type": "object",
      "properties": {
        "hits": { "type": "integer", "minimum": 0 },
        "misses": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "anchor-metrics": {
      "type": "object",
      "required": ["total", "confidence", "generic_fallback_count", "generic_fallback_rate"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "confidence": {
          "type": "object",
          "required": ["high", "medium", "low"],
          "properties": {
            "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "specificity": {
          "type": "object",
          "required": ["concrete-check", "category-check", "generic"],
          "properties": {
            "concrete-check": { "type": "integer", "minimum": 0 },
            "category-check": { "type": "integer", "minimum": 0 },
            "generic": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "actionable_proxy_count": { "type": "integer", "minimum": 0 },
        "actionable_proxy_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "generic_fallback_count": { "type": "integer", "minimum": 0 },
        "generic_fallback_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "issue": {
      "type": "object",
      "required": ["id", "title", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": ["integer", "null"] },
        "labels": { "type": "array", "items": { "type": "string" } },
        "parent_id": { "type": ["string", "null"] },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "issue_id", "related_issue_id", "similarity", "what_to_verify"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "issue_id": { "type": "string", "minLength": 1 },
        "related_issue_id": { "type": "string", "minLength": 1 },
        "similarity": { "type": "number", "minimum": -1, "maximum": 1 },
        "structural_context": { "type": "string" },
        "reciprocal_evidence": {
          "type": ["string", "null"],
          "enum": [null, "discriminative-title-token", "discriminative-title-alignment", "discriminative-field-phrase"]
        },
        "verification_anchor": {
          "type": "object",
          "required": ["category", "operation", "entity_class", "source_field"],
          "properties": {
            "category": { "type": "string", "minLength": 1 },
            "operation": { "type": "string", "minLength": 1 },
            "entity_class": { "type": "string", "minLength": 1 },
            "source_field": { "type": "string", "minLength": 1 },
            "action": { "type": "string", "minLength": 1 },
            "entity": { "type": "string", "minLength": 1 },
            "outcome_or_invariant": { "type": "string", "minLength": 1 },
            "confidence": { "enum": ["high", "medium", "low"] },
            "extraction_confidence": { "enum": ["high", "medium", "low"] },
            "confidence_scope": { "const": "anchor-extraction" },
            "specificity": { "enum": ["concrete-check", "category-check", "generic"] },
            "check_category": { "enum": ["ownership-boundary", "test", "invariant", "contract", "artifact", "entity-category", "unspecified"] },
            "check_source_field": { "enum": ["title", "description", "acceptance criteria", "design", "notes", "whole-record semantics"] },
            "generic_fallback": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "candidate_evidence": {
          "type": "object",
          "required": ["evidence_basis", "structural_corroboration", "admission_path", "uncertainty"],
          "properties": {
            "evidence_basis": { "enum": ["semantic-only", "structurally-corroborated"] },
            "structural_corroboration": { "enum": ["none", "shared-parent", "typed-dependency"] },
            "admission_path": { "enum": ["semantic-threshold", "shared-parent-threshold-exception", "dependency-threshold-exception", "reciprocal-neighbor-threshold-exception"] },
            "uncertainty": { "enum": ["no-structural-corroboration", "structural-corroboration-recorded"] }
          },
          "additionalProperties": false
        },
        "what_to_verify": { "type": "string", "minLength": 1 },
        "counterevidence": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
